{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Patient file in PerioDash containing clinical dental records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "birthdate": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "odontogram": { "type": "object" },
        "periodontogram": { "type": "object" },
        "oLeary": { "type": "object" },
        "anamnesis": { "type": "object" },
        "xRays": { "type": "array" },
        "treatmentPlan": { "type": "object" },
        "evolutions": { "type": "array" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment scheduled for a Patient.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "treatment": { "type": "string" },
        "status": { "type": "string" },
        "box": { "type": "string" }
      },
      "required": ["id", "patientId", "date", "time", "status"]
    }
  },
  "firestore": {
    "patients/{patientId}": {
      "schema": "Patient",
      "description": "Read and write clinical files for patients."
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Clinical appointment records."
    }
  }
}
